{
  "stryker-config": {
    "mutate": [
      "src/**/*.cs",
      "!src/**/*Marker.cs",
      "!src/MonAssurance.Api/Program.cs"
    ],
    "test-runner": "dotnet",
    "reporters": [
      "html"
    ],
    "output-path": "stryker-mutation-report",
    "test-runner-args": {
      "project": "MonAssurance.sln"
    },
    "exclude-mutations": [
      "String",
      "Bitwise"
    ],
    "log-level": "info",
    "timeout-ms": 5000,
    "concurrency": 4,
    "since": {
      "enabled": true
    }
  }
}
